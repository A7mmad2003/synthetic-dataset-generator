# ==============================================================================
# .gitignore — Synthetic Dataset Generator
# ==============================================================================
# Covers: Python bytecode, virtual environments, common OS files,
#         Streamlit cache, Jupyter notebooks, and data files that should
#         never be committed (could contain real/sensitive user data).
# ==============================================================================


# ── Python ────────────────────────────────────────────────────────────────────

# Compiled bytecode — regenerated automatically, never commit
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging artifacts
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log


# ── Virtual environments ──────────────────────────────────────────────────────

# Common venv folder names
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Conda environments
*.conda
.conda/

# pyenv
.python-version


# ── Environment variables / secrets ──────────────────────────────────────────

# NEVER commit API keys or credentials
.env
.env.local
.env.*.local
*.secret
secrets.toml


# ── Streamlit ─────────────────────────────────────────────────────────────────

# Streamlit's local cache directory (stores compiled component bundles)
.streamlit/secrets.toml     # Secret management — never commit
# .streamlit/config.toml    # App configuration — OK to commit if desired


# ── Data files ────────────────────────────────────────────────────────────────

# Never commit uploaded or generated datasets — they may contain real user data
data/
*.csv
*.tsv
*.parquet
*.feather
*.xlsx
*.xls
*.json
# Exception: you can explicitly un-ignore example/demo files if needed:
# !examples/demo_dataset.csv


# ── Jupyter / IPython ─────────────────────────────────────────────────────────

.ipynb_checkpoints/
*.ipynb           # Comment out if you want to track notebooks in version control
profile_default/
ipython_config.py


# ── IDEs and editors ──────────────────────────────────────────────────────────

# Visual Studio Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.cfg
.spyproject/


# ── macOS ─────────────────────────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
*.AppleDouble


# ── Windows ───────────────────────────────────────────────────────────────────

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk


# ── Linux ─────────────────────────────────────────────────────────────────────

*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ── Logs ──────────────────────────────────────────────────────────────────────

*.log
logs/
log/


# ── Misc ──────────────────────────────────────────────────────────────────────

# Byte-compiled / optimised files from other languages
*.class

# Temporary files
*.tmp
*.temp
*.bak
*.orig
